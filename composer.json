{
    "name": "waaseyaa/menu",
    "description": "Menu and navigation link management for Waaseyaa",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "repositories": [
        {
            "type": "path",
            "url": "../entity"
        },
        {
            "type": "path",
            "url": "../access"
        },
        {
            "type": "path",
            "url": "../foundation"
        }
    ],
    "require": {
        "php": ">=8.5",
        "waaseyaa/entity": "^0.1.0-alpha.271",
        "waaseyaa/access": "^0.1.0-alpha.271",
        "waaseyaa/foundation": "^0.1.0-alpha.271"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Menu\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waaseyaa\\Menu\\Tests\\": "tests/"
        }
    },
    "extra": {
        "waaseyaa": {
            "policies": [
                "Waaseyaa\\Menu\\MenuAccessPolicy"
            ],
            "providers": [
                "Waaseyaa\\Menu\\MenuServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev",
            "dev-develop/v1.1": "0.1.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
